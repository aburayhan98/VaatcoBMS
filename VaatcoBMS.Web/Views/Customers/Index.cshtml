@{
  ViewData["Title"] = "Customers";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-icon blue"><i class="bi bi-building"></i></div>
    <div><div class="stat-label">Total Customers</div><div class="stat-value" id="statTotal">—</div></div>
  </div>
</div>

<div class="vcard">
  <div class="vcard-header">
    <i class="bi bi-building" style="font-size:16px;color:#64748b;"></i>
    <span class="vcard-title">Customer Directory</span>

    <div class="search-bar" style="margin-left:auto;">
      <i class="bi bi-search"></i>
      <input type="text" id="custSearch" placeholder="Search customers…" />
    </div>
  </div>

  <div style="overflow-x:auto;">
    <table class="vtable">
      <thead>
        <tr>
          <th>Name</th>
          <th>Contact</th>
          <th>Email</th>
          <th>Phone</th>
          <th>City</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody id="customerBody">
        <tr>
          <td colspan="6" style="text-align:center;padding:48px;color:var(--text-muted);">
            <div class="spinner-border spinner-border-sm text-primary"></div> Loading customers...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- THIS IS WHERE THE JS WILL INJECT THE BUTTONS -->
  <div id="paginationContainer"></div>
</div>

@section Scripts {
  <script>
    // 1. The Current State payload
    var state = {
        page: 1,
        pageSize: 20,
        search: ''
    };

    $(function () {
        loadCustomers();

        // Search typing logic with Debounce
        var typingTimer;
        $('#custSearch').on('keyup', function () {
            clearTimeout(typingTimer);
            var val = $(this).val();
            typingTimer = setTimeout(function () {
                state.search = val;
                state.page = 1;      // Reset to page 1 on new search
                loadCustomers();
            }, 400); // 400ms delay
        });
    });

    // 2. Fetch the data from the backend API
    function loadCustomers() {
        var qs = `?page=${state.page}&pageSize=${state.pageSize}&search=${encodeURIComponent(state.search)}`;

        $.get('/api/customers' + qs)
            .done(function (res) {
                var html = '';
                if (!res.data || !res.data.length) {
                    html = `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted);">
                              <i class="bi bi-inbox" style="font-size:32px;display:block;margin-bottom:8px;"></i>
                              No customers found.
                            </td></tr>`;
                } else {
                    html = res.data.map(buildCustomerRow).join('');
                }

                $('#customerBody').html(html);

                // Update stats
                $('#statTotal').text(res.meta?.totalCount?.toLocaleString() ?? 0);

                // 3. MAGIC: Pass the API Meta object right into the pagination renderer!
                renderPagination(res.meta);
            })
            .fail(function () {
                $('#customerBody').html(`<tr><td colspan="6" style="text-align:center;color:red;">Failed to load data.</td></tr>`);
            });
    }

    // 4. Draw the HTML for a single row
    function buildCustomerRow(c) {
        return `<tr>
            <td style="font-weight:500;">${c.name}</td>
            <td style="color:var(--text-secondary);">${c.contactPerson || '—'}</td>
            <td style="color:var(--text-secondary);">${c.email || '—'}</td>
            <td style="font-weight:500;">${c.phone}</td>
            <td><span class="vbadge blue">${c.city || '—'}</span></td>
            <td style="text-align:right;">
                <button class="btn-action edit" onclick="editCustomer(${c.id})" title="Edit">
                    <i class="bi bi-pencil"></i>
                </button>
                ${c.id > 0 ? `
                <button class="btn-action delete" onclick="deleteCustomer(${c.id})" title="Delete">
                    <i class="bi bi-trash3"></i>
                </button>` : ''}
            </td>
        </tr>`;
    }

    // 5. The REUSABLE Pagination Renderer
    function renderPagination(meta) {
        if (!meta || meta.totalPages <= 1) {
            $('#paginationContainer').html(
                `<div class="vpager"><span class="vpager-info">${meta?.totalCount?.toLocaleString() ?? 0} customers</span></div>`
            );
            return;
        }

        var start = Math.max(1, meta.page - 2);
        var end   = Math.min(meta.totalPages, start + 4);
        if (end - start < 4) start = Math.max(1, end - 4);

        var pageButtons = '';
        for (var p = start; p <= end; p++) {
            pageButtons += `<button class="vpager-btn${p === meta.page ? ' active' : ''}"
                                    onclick="changePage(${p})">${p}</button>`;
        }

        var sizeOptions = [10, 20, 50, 100].map(function (sz) {
            return `<option value="${sz}"${sz === meta.pageSize ? ' selected' : ''}>${sz} / page</option>`;
        }).join('');

        $('#paginationContainer').html(`
            <div class="vpager" style="justify-content:space-between;flex-wrap:wrap;gap:8px;">
                <span class="vpager-info">
                    Page <strong>${meta.page}</strong> of <strong>${meta.totalPages}</strong>
                    &nbsp;·&nbsp; ${meta.totalCount.toLocaleString()} records
                </span>
                <div style="display:flex;align-items:center;gap:4px;">
                    <button class="vpager-btn" onclick="changePage(1)"
                            ${meta.hasPrev ? '' : 'disabled'} title="First">«</button>
                    <button class="vpager-btn" onclick="changePage(${meta.page - 1})"
                            ${meta.hasPrev ? '' : 'disabled'} title="Prev">‹</button>
                    ${pageButtons}
                    <button class="vpager-btn" onclick="changePage(${meta.page + 1})"
                            ${meta.hasNext ? '' : 'disabled'} title="Next">›</button>
                    <button class="vpager-btn" onclick="changePage(${meta.totalPages})"
                            ${meta.hasNext ? '' : 'disabled'} title="Last">»</button>
                    <select onchange="changePageSize(this.value)" class="form-control-v"
                            style="margin-left:12px;width:95px;padding:5px 8px;font-size:12px;">
                        ${sizeOptions}
                    </select>
                </div>
            </div>`);
    }

    // Pagination Triggers
    function changePage(p) { state.page = p; loadCustomers(); }
    function changePageSize(s){ state.pageSize = parseInt(s); state.page = 1; loadCustomers(); }
  </script>
}