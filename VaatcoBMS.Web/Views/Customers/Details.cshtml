@model VaatcoBMS.Application.DTOs.Customer.CustomerDto

@{
  ViewData["Title"] = "Customer Details";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="customer-details-page">
  <div class="customer-card">

    <div class="customer-header">
      <div>
        <div class="header-icon">
          <i class="bi bi-person-badge"></i>
        </div>
        <div>
          <h3>Customer Details</h3>
          <p>View customer profile, contact and billing information</p>
        </div>
      </div>

      @if (Model.IsActive)
      {
        <span class="status-badge active">
          <i class="bi bi-check-circle"></i> Active
        </span>
      }
      else
      {
        <span class="status-badge inactive">
          <i class="bi bi-x-circle"></i> Inactive
        </span>
      }
    </div>

    <div class="customer-profile">
      <div>
        <h2>@Model.Name</h2>
        <span class="customer-code">
          <i class="bi bi-upc-scan"></i>
          @Model.CustomerCode
        </span>
      </div>
    </div>

    <div class="details-grid">

      <div class="info-card">
        <div class="section-title">
          <i class="bi bi-person-lines-fill"></i>
          <span>Basic Information</span>
        </div>

        <div class="info-row">
          <label>Contact Person</label>
          <span>@(string.IsNullOrEmpty(Model.ContactPerson) ? "—" : Model.ContactPerson)</span>
        </div>

        <div class="info-row">
          <label>Phone</label>
          <span>
            <i class="bi bi-telephone"></i>
            @Model.Phone
          </span>
        </div>

        <div class="info-row">
          <label>Email</label>
          <span>
            <i class="bi bi-envelope"></i>
            @(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)
          </span>
        </div>
      </div>

      <div class="info-card">
        <div class="section-title">
          <i class="bi bi-geo-alt"></i>
          <span>Location Information</span>
        </div>

        <div class="info-row">
          <label>Address</label>
          <span>@Model.Address</span>
        </div>

        <div class="info-row">
          <label>City</label>
          <span>@(string.IsNullOrEmpty(Model.City) ? "—" : Model.City)</span>
        </div>

        <div class="info-row">
          <label>District</label>
          <span>@(string.IsNullOrEmpty(Model.District) ? "—" : Model.District)</span>
        </div>
      </div>

    </div>

    <div class="billing-card">
      <div>
        <i class="bi bi-receipt"></i>
        <div>
          <h5>Billing Summary</h5>
          <p>Total invoices generated for this customer</p>
        </div>
      </div>

      <strong>@Model.TotalInvoices</strong>
    </div>

    <div class="customer-actions">
      <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">
        <i class="bi bi-pencil-square"></i>
        Edit Customer
      </a>

      <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i>
        Back to Directory
      </a>
    </div>

  </div>
</div>

<style>
  .customer-details-page {
    max-width: 950px;
    margin: 0 auto;
    padding: 24px;
  }

  .customer-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
  }

  .customer-header {
    padding: 22px 26px;
    background: linear-gradient(135deg, #f8fafc, #eef6ff);
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

    .customer-header > div:first-child {
      display: flex;
      align-items: center;
      gap: 14px;
    }

  .header-icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: #dbeafe;
    color: #2563eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }

  .customer-header h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
  }

  .customer-header p {
    margin: 3px 0 0;
    color: #64748b;
    font-size: 0.9rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 13px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
  }

    .status-badge.active {
      background: #dcfce7;
      color: #166534;
    }

    .status-badge.inactive {
      background: #fee2e2;
      color: #991b1b;
    }

  .customer-profile {
    padding: 26px;
    border-bottom: 1px solid #f1f5f9;
  }

    .customer-profile h2 {
      margin: 0 0 8px;
      color: #111827;
      font-size: 1.6rem;
      font-weight: 700;
    }

  .customer-code {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #f1f5f9;
    color: #475569;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
  }

  .details-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    padding: 26px;
  }

  .info-card {
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 18px;
    background: #ffffff;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #334155;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid #f1f5f9;
  }

    .section-title i {
      color: #2563eb;
    }

  .info-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 14px;
  }

    .info-row:last-child {
      margin-bottom: 0;
    }

    .info-row label {
      color: #94a3b8;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .info-row span {
      color: #1e293b;
      font-size: 15px;
      font-weight: 500;
    }

      .info-row span i {
        color: #64748b;
        margin-right: 5px;
      }

  .billing-card {
    margin: 0 26px 26px;
    padding: 18px;
    border-radius: 14px;
    background: linear-gradient(135deg, #eff6ff, #f0f9ff);
    border: 1px solid #bfdbfe;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

    .billing-card > div {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .billing-card i {
      font-size: 24px;
      color: #2563eb;
    }

    .billing-card h5 {
      margin: 0;
      color: #0f172a;
      font-size: 1rem;
      font-weight: 700;
    }

    .billing-card p {
      margin: 3px 0 0;
      color: #64748b;
      font-size: 13px;
    }

    .billing-card strong {
      font-size: 1.8rem;
      color: #1d4ed8;
    }

  .customer-actions {
    padding: 18px 26px;
    background: #f8fafc;
    border-top: 1px solid #e5e7eb;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-edit,
  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    border-radius: 10px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .btn-edit {
    background: #2563eb;
    color: #ffffff;
    border: 1px solid #2563eb;
  }

    .btn-edit:hover {
      background: #1d4ed8;
      color: #ffffff;
      transform: translateY(-1px);
    }

  .btn-back {
    background: #ffffff;
    color: #475569;
    border: 1px solid #cbd5e1;
  }

    .btn-back:hover {
      background: #f1f5f9;
      color: #334155;
      transform: translateY(-1px);
    }

  @@media (max-width: 768px) {
    .customer-details-page {
      padding: 14px;
    }

    .customer-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .details-grid {
      grid-template-columns: 1fr;
      padding: 18px;
    }

    .customer-profile {
      padding: 18px;
    }

    .billing-card {
      margin: 0 18px 18px;
      align-items: flex-start;
      flex-direction: column;
    }

    .customer-actions {
      padding: 18px;
    }
  }
</style>