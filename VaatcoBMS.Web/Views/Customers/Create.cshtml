@model VaatcoBMS.Application.DTOs.Customer.CreateCustomerDto

@{
  ViewData["Title"] = "Create Customer";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="vcard">
  <div class="vcard-header">
    <i class="bi bi-building" style="font-size:16px;color:#64748b;"></i>
    <span class="vcard-title">Create Customer</span>
  </div>
  <div class="vcard-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="text-danger"></div>

      <div class="form-group-v">
        <label class="form-label-v">Business Name *</label>
        <input asp-for="Name" class="form-control-v" />
        <span asp-validation-for="Name" class="text-danger"></span>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group-v">
          <label class="form-label-v">Customer Code</label>
          <input asp-for="CustomerCode" class="form-control-v" />
        </div>
        <div class="form-group-v">
          <label class="form-label-v">Contact Person</label>
          <input asp-for="ContactPerson" class="form-control-v" />
        </div>
      </div>

      <div class="form-group-v">
        <label class="form-label-v">Address</label>
        <input asp-for="Address" class="form-control-v" />
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group-v">
          <label class="form-label-v">City</label>
          <input asp-for="City" class="form-control-v" />
        </div>
        <div class="form-group-v">
          <label class="form-label-v">District</label>
          <input asp-for="District" class="form-control-v" />
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group-v">
          <label class="form-label-v">Phone *</label>
          <input asp-for="Phone" class="form-control-v" />
          <span asp-validation-for="Phone" class="text-danger"></span>
        </div>
        <div class="form-group-v">
          <label class="form-label-v">Email</label>
          <input asp-for="Email" class="form-control-v" />
        </div>
      </div>

      <div style="display:flex;gap:8px;margin-top:12px;">
        <button type="submit" class="btn-primary-v"><i class="bi bi-save"></i> Create</button>
        <a asp-action="Index" class="btn-outline-v">Cancel</a>
      </div>
    </form>
  </div>
</div>