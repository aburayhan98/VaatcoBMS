@model IEnumerable<VaatcoBMS.Application.DTOs.User.UserDto>

@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="vcard">
    <div class="vcard-header">
        <i class="bi bi-people-fill" style="font-size:16px;color:#64748b;"></i>
        <span class="vcard-title">Approved Users</span>
    </div>

    <div style="overflow-x:auto;">
        <table class="vtable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td style="font-weight:500;">@user.Name</td>
                        <td style="color:var(--text-secondary);">@user.Email</td>
                        <td><span class="vbadge blue">@user.Role</span></td>
                        <td>
                            @if(user.IsApproved) {
                                <span class="vbadge green">Active</span>
                            } else {
                                <span class="vbadge gray">Inactive</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" style="text-align:center;padding:40px;">No approved users found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>