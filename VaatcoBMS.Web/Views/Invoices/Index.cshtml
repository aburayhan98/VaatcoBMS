@{
  ViewData["Title"] = "Invoices";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="stat-grid" id="invoiceStats">
  <div class="stat-card">
    <div class="stat-icon blue"><i class="bi bi-receipt"></i></div>
    <div><div class="stat-label">Total Invoices</div><div class="stat-value" id="statTotal">—</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon gray"><i class="bi bi-pencil-square"></i></div>
    <div><div class="stat-label">Draft</div><div class="stat-value" id="statDraft">—</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><i class="bi bi-check2-circle"></i></div>
    <div><div class="stat-label">Paid</div><div class="stat-value" id="statPaid">—</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber"><i class="bi bi-hourglass-split"></i></div>
    <div>
      <div class="stat-label">Total Revenue</div>
      <div class="stat-value" id="statRevenue" style="font-size:16px;">—</div>
    </div>
  </div>
</div>

<div class="vcard">
  <div class="vcard-header">
    <i class="bi bi-receipt" style="font-size:16px;color:#64748b;"></i>
    <span class="vcard-title">Invoices</span>

    <div class="search-bar" style="margin-left:auto;">
      <i class="bi bi-search"></i>
      <input type="text" id="invoiceSearch" placeholder="Search invoice # or customer..." />
    </div>

    <select id="statusFilter" class="form-control-v" style="width:130px;padding:7px 10px;">
      <option value="">All Status</option>
      <option value="Draft">Draft</option>
      <option value="Approved">Approved</option>
      <option value="Paid">Paid</option>
      <option value="Cancelled">Cancelled</option>
    </select>

    <a href="/Invoices/Create" class="btn-primary-v" style="margin-left:12px;">
      <i class="bi bi-plus-lg"></i> Create Invoice
    </a>
  </div>

  <div style="overflow-x:auto;">
    <table class="vtable">
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Customer</th>
          <th>Date</th>
          <th style="text-align:right;">Amount</th>
          <th>Status</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody id="invoiceBody">
        <tr>
          <td colspan="6" style="text-align:center;padding:48px;color:var(--text-muted);">
            <div class="spinner-border spinner-border-sm text-primary"></div> Loading invoices...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <div id="paginationContainer"></div>
</div>

@section Scripts {
  <script>
    var state = {
        page: 1,
        pageSize: 20,
        search: '',
        status: ''
    };

    $(function () {
        loadStats();
        loadInvoices();

        var typingTimer;
        $('#invoiceSearch').on('keyup', function () {
            clearTimeout(typingTimer);
            var val = $(this).val();
            typingTimer = setTimeout(function () {
                state.search = val;
                state.page = 1;
                loadInvoices();
            }, 400);
        });

        $('#statusFilter').on('change', function () {
            state.status = $(this).val();
            state.page = 1;
            loadInvoices();
        });
    });

    function loadStats() {
        $.get('/api/invoices/stats').done(function (r) {
            if (r && r.data) {
                $('#statTotal').text(r.data.totalCount.toLocaleString());
                $('#statDraft').text(r.data.draftCount.toLocaleString());
                $('#statPaid').text(r.data.paidCount.toLocaleString());
                $('#statRevenue').text('৳ ' + r.data.totalRevenue.toLocaleString(undefined, {minimumFractionDigits: 2}));
            }
        });
    }

    function loadInvoices() {
        var qs = `?page=${state.page}&pageSize=${state.pageSize}&search=${encodeURIComponent(state.search)}&status=${encodeURIComponent(state.status)}`;

        $.get('/api/invoices' + qs)
            .done(function (res) {
                var html = '';
                if (!res.data || !res.data.length) {
                    html = `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted);">
                              <i class="bi bi-inbox" style="font-size:32px;display:block;margin-bottom:8px;"></i>
                              No invoices found.
                            </td></tr>`;
                } else {
                    html = res.data.map(buildInvoiceRow).join('');
                }

                $('#invoiceBody').html(html);
                renderPagination(res.meta);
            })
            .fail(function () {
                $('#invoiceBody').html(`<tr><td colspan="6" style="text-align:center;color:red;">Failed to load.</td></tr>`);
            });
    }

    function buildInvoiceRow(i) {
        var statusColor = { 'Draft':'gray', 'Approved':'blue', 'Paid':'green', 'Cancelled':'red' }[i.status] || 'gray';
        var dateStr = new Date(i.invoiceDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

        return `<tr>
            <td style="font-weight:600;"><a href="/Invoices/${i.id}" style="text-decoration:none;color:var(--primary);">${i.invoiceNumber}</a></td>
            <td><div style="font-weight:500;">${i.customerName}</div></td>
            <td style="color:var(--text-secondary);font-size:12px;">${dateStr}</td>
            <td style="text-align:right;font-weight:600;">৳ ${i.totalAmount.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
            <td><span class="vbadge ${statusColor}">${i.status}</span></td>
            <td style="text-align:right;">
                <a href="/Invoices/${i.id}" class="btn-action edit" title="View Details">
                    <i class="bi bi-eye"></i>
                </a>
            </td>
        </tr>`;
    }

    function renderPagination(meta) {
        if (!meta || meta.totalPages <= 1) {
            $('#paginationContainer').html(`<div class="vpager"><span class="vpager-info">${meta?.totalCount?.toLocaleString() ?? 0} invoices</span></div>`);
            return;
        }

        var start = Math.max(1, meta.page - 2);
        var end   = Math.min(meta.totalPages, start + 4);
        if (end - start < 4) start = Math.max(1, end - 4);

        var pageButtons = '';
        for (var p = start; p <= end; p++) {
            pageButtons += `<button class="vpager-btn${p === meta.page ? ' active' : ''}" onclick="changePage(${p})">${p}</button>`;
        }

        var sizeOptions = [10, 20, 50, 100].map(sz => `<option value="${sz}"${sz === meta.pageSize ? ' selected' : ''}>${sz} / page</option>`).join('');

        $('#paginationContainer').html(`
            <div class="vpager" style="justify-content:space-between;flex-wrap:wrap;gap:8px;">
                <span class="vpager-info">
                    Page <strong>${meta.page}</strong> of <strong>${meta.totalPages}</strong>
                    &nbsp;·&nbsp; ${meta.totalCount.toLocaleString()} records
                </span>
                <div style="display:flex;align-items:center;gap:4px;">
                    <button class="vpager-btn" onclick="changePage(1)" ${meta.hasPrev ? '' : 'disabled'} title="First">«</button>
                    <button class="vpager-btn" onclick="changePage(${meta.page - 1})" ${meta.hasPrev ? '' : 'disabled'} title="Prev">‹</button>
                    ${pageButtons}
                    <button class="vpager-btn" onclick="changePage(${meta.page + 1})" ${meta.hasNext ? '' : 'disabled'} title="Next">›</button>
                    <button class="vpager-btn" onclick="changePage(${meta.totalPages})" ${meta.hasNext ? '' : 'disabled'} title="Last">»</button>
                    <select onchange="changePageSize(this.value)" class="form-control-v" style="margin-left:12px;width:95px;padding:5px 8px;font-size:12px;">
                        ${sizeOptions}
                    </select>
                </div>
            </div>`);
    }

    function changePage(p) { state.page = p; loadInvoices(); }
    function changePageSize(s){ state.pageSize = parseInt(s); state.page = 1; loadInvoices(); }
  </script>
}
