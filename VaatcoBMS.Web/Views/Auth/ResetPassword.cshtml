@model VaatcoBMS.Application.Model.Auth.ResetPasswordModel

@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <h4 class="auth-title">Set a new password</h4>
    <p class="auth-sub">Enter and confirm your new password</p>

    <form asp-action="ResetPassword" method="post" id="resetForm" novalidate>
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Email" value="@(ViewBag.Email as string ?? "")" />
        <input type="hidden" name="token" value="@ViewBag.Token" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">New Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters" id="newPass" />
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat new password" id="confirmPass" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            <div id="matchMsg" class="small mt-1"></div>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-auth" id="resetBtn">
            <span class="btn-text">Reset Password</span>
            <span class="btn-spinner spinner-border spinner-border-sm d-none"></span>
        </button>
    </form>
</div>

@section Scripts {
    <script>
        // Live password match check
        $("#confirmPass, #newPass").on("input", function() {
            const match = $("#newPass").val() === $("#confirmPass").val();
            const msg = $("#matchMsg");
            
            if ($("#confirmPass").val().length === 0) {
                msg.html("");
                return;
            }
            
            msg.html(match 
                ? '<span class="text-success"><i class="bi bi-check-circle-fill"></i> Passwords match</span>' 
                : '<span class="text-danger"><i class="bi bi-x-circle-fill"></i> Passwords do not match</span>');
        });

        $("#resetForm").on("submit", function() {
            if ($(this).valid()) {
                $("#resetBtn .btn-text").text("Resetting...");
                $("#resetBtn .btn-spinner").removeClass("d-none");
                $("#resetBtn").prop("disabled", true);
            }
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}