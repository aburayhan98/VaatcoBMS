@model VaatcoBMS.Application.Model.Auth.ForgotPasswordModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <h4 class="auth-title">Reset your password</h4>
    <p class="auth-sub">Enter your email and we will send a reset link</p>

    <form asp-action="ForgotPassword" method="post" id="forgotForm" novalidate>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email address</label>
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-envelope-fill"></i>
                </span>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-auth" id="forgotBtn">
            <span class="btn-text">Send Reset Link</span>
            <span class="btn-spinner spinner-border spinner-border-sm d-none"></span>
        </button>
    </form>

    <p class="auth-footer">
        <a asp-action="Login">
            <i class="bi bi-arrow-left"></i> Back to Login
        </a>
    </p>
</div>

@section Scripts {
    <script>
        $("#forgotForm").on("submit", function() {
            if ($(this).valid()) {
                $("#forgotBtn .btn-text").text("Sending...");
                $("#forgotBtn .btn-spinner").removeClass("d-none");
                $("#forgotBtn").prop("disabled", true);
            }
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}