@{
  ViewData["Title"] = "Dashboard";
  Layout = "~/Views/Shared/_Layout.cshtml";

  // Cache the authorization check at the top
  var isAdmin = User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
}

@* ── Move inline hover JS to proper CSS best practices ── *@
<style>
  .quick-action-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 9px;
    text-decoration: none;
    color: var(--text-primary);
    background: var(--body-bg);
    transition: .14s;
  }

  .qa-success:hover {
    background: var(--success-light);
  }

  .qa-primary:hover {
    background: var(--primary-light);
  }

  .qa-warning:hover {
    background: var(--warning-light);
  }
</style>

@* Welcome Banner *@
<div style="background:linear-gradient(135deg,#1e4db7 0%,#1a40a0 100%);border-radius:14px;padding:24px 28px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;">
  <div>
    <div style="font-size:11px;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;">Welcome back</div>
    <div style="font-size:22px;font-weight:600;color:#fff;margin-bottom:4px;">@(User.Identity?.Name ?? "User")</div>
    <div style="font-size:13px;color:rgba(255,255,255,.65);">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</div>
  </div>
  <div style="display:flex;gap:10px;">
    @if (isAdmin)
    {
      <a href="/admin/pending" class="btn-primary-v" style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);">
        <i class="bi bi-person-check"></i> Pending
        <span id="pendingBadgeBanner" class="vbadge red" style="display:none;margin-left:4px;"></span>
      </a>
    }
    <a href="/Invoices/Create" class="btn-primary-v" style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.3);">
      <i class="bi bi-plus-lg"></i> New Invoice
    </a>
  </div>
</div>

@* Revenue Stats *@
<div class="stat-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <div class="stat-icon blue"><i class="bi bi-receipt"></i></div>
    <div><div class="stat-label">Total Invoices</div><div class="stat-value" id="statTotal">—</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><i class="bi bi-cash-stack"></i></div>
    <div>
      <div class="stat-label">Revenue</div>
      <div class="stat-value" id="statRevenue" style="font-size:16px;">—</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber"><i class="bi bi-wallet2"></i></div>
    <div>
      <div class="stat-label">Outstanding</div>
      <div class="stat-value" id="statOutstanding" style="font-size:16px;">—</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue"><i class="bi bi-building"></i></div>
    <div><div class="stat-label">Customers</div><div class="stat-value" id="statCustomers">—</div></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 340px;gap:20px;">

  @* Recent Invoices *@
  <div>
    <div class="vcard" style="margin-bottom:16px;">
      <div class="vcard-header">
        <i class="bi bi-clock-history" style="font-size:15px;color:#64748b;"></i>
        <span class="vcard-title">Recent Invoices</span>
        <a href="/Invoices" class="btn-outline-v" style="margin-left:auto;padding:5px 12px;font-size:12px;">
          View All <i class="bi bi-arrow-right" style="font-size:11px;"></i>
        </a>
      </div>
      <div style="overflow-x:auto;">
        <table class="vtable" id="recentInvoices">
          <thead>
            <tr>
              <th>Invoice #</th>
              <th>Customer</th>
              <th>Amount</th>
              <th>Balance</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="6" style="text-align:center;padding:32px;color:var(--text-muted);">
                <div class="spinner-border spinner-border-sm text-primary"></div>
                <span style="margin-left:8px;font-size:13px;">Loading…</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    @* Low Stock Alerts *@
    <div class="vcard" id="lowStockCard" style="display:none;">
      <div class="vcard-header">
        <i class="bi bi-exclamation-triangle-fill" style="font-size:15px;color:var(--warning);"></i>
        <span class="vcard-title" style="color:var(--warning);">Low Stock Alert</span>
        <a href="/Products" class="btn-outline-v" style="margin-left:auto;padding:5px 12px;font-size:12px;">View Products</a>
      </div>
      <div id="lowStockList" style="display:flex;flex-direction:column;gap:0;"></div>
    </div>
  </div>

  @* Right panel *@
  <div style="display:flex;flex-direction:column;gap:16px;">

    @* Invoice Status Breakdown *@
    <div class="vcard">
      <div class="vcard-header">
        <i class="bi bi-pie-chart-fill" style="font-size:15px;color:#64748b;"></i>
        <span class="vcard-title">Invoice Status</span>
      </div>
      <div class="vcard-body" style="display:flex;flex-direction:column;gap:8px;" id="statusBreakdown">
        <div style="text-align:center;padding:16px;color:var(--text-muted);">
          <div class="spinner-border spinner-border-sm text-primary"></div>
        </div>
      </div>
    </div>

    @* Quick Actions *@
    <div class="vcard">
      <div class="vcard-header">
        <i class="bi bi-lightning-fill" style="font-size:15px;color:#64748b;"></i>
        <span class="vcard-title">Quick Actions</span>
      </div>
      <div class="vcard-body" style="display:flex;flex-direction:column;gap:8px;">
        <a href="/Invoices/Create" class="quick-action-link qa-success">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--success-light);color:var(--success);display:flex;align-items:center;justify-content:center;font-size:15px;"><i class="bi bi-receipt-cutoff"></i></div>
          <span style="font-size:13px;font-weight:500;">Create Invoice</span>
          <i class="bi bi-chevron-right" style="font-size:11px;color:var(--text-muted);margin-left:auto;"></i>
        </a>
        <a href="/Customers/Create" class="quick-action-link qa-primary">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:15px;"><i class="bi bi-building-add"></i></div>
          <span style="font-size:13px;font-weight:500;">Add Customer</span>
          <i class="bi bi-chevron-right" style="font-size:11px;color:var(--text-muted);margin-left:auto;"></i>
        </a>
        <a href="/Products" class="quick-action-link qa-warning">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--warning-light);color:var(--warning);display:flex;align-items:center;justify-content:center;font-size:15px;"><i class="bi bi-box-seam-fill"></i></div>
          <span style="font-size:13px;font-weight:500;">Manage Products</span>
          <i class="bi bi-chevron-right" style="font-size:11px;color:var(--text-muted);margin-left:auto;"></i>
        </a>
      </div>
    </div>

    @* Pending Approvals *@
    @if (isAdmin)
    {
      <div class="vcard">
        <div class="vcard-header">
          <i class="bi bi-person-check" style="font-size:15px;color:#64748b;"></i>
          <span class="vcard-title">Awaiting Approval</span>
          <a href="/admin/pending" style="margin-left:auto;font-size:12px;color:var(--primary);text-decoration:none;">See all</a>
        </div>
        <div id="pendingMini" style="padding:8px 0;">
          <div style="text-align:center;padding:16px;color:var(--text-muted);font-size:13px;">
            <div class="spinner-border spinner-border-sm text-primary"></div>
          </div>
        </div>
      </div>
    }
  </div>
</div>

@section Scripts {
  <script>
    // Store Razor calculation as a safe JS boolean to prevent IDE script parsing warnings
    var isUserAdmin = @(isAdmin.ToString().ToLower())

    $(function () {
        // Invoice stats
        $.get('/api/invoices/stats', function (r) {
            var s = r.data;
            $('#statTotal').text(s.totalInvoices);
            $('#statRevenue').text('৳ ' + parseFloat(s.totalRevenue || 0).toLocaleString('en-BD', {minimumFractionDigits:0}));
            $('#statOutstanding').text('৳ ' + parseFloat(s.totalOutstanding || 0).toLocaleString('en-BD', {minimumFractionDigits:0}));

            // Status breakdown
            var items = [
                { label: 'Draft', count: s.draftCount, cls: 'gray' },
                { label: 'Approved', count: s.approvedCount, cls: 'blue' },
                { label: 'Paid', count: s.paidCount, cls: 'green' },
                { label: 'Cancelled', count: s.cancelledCount, cls: 'red' },
            ];
            var html = items.map(function (it) {
                var pct = s.totalInvoices > 0 ? Math.round(it.count / s.totalInvoices * 100) : 0;
                return `<div style="display:flex;align-items:center;gap:10px;">
                    <span class="vbadge ${it.cls}" style="min-width:76px;justify-content:center;">${it.label}</span>
                    <div style="flex:1;height:6px;border-radius:3px;background:#e2e8f0;overflow:hidden;">
                        <div style="height:100%;border-radius:3px;width:${pct}%;background:var(--${it.cls === 'gray' ? 'text-muted' : it.cls === 'green' ? 'success' : it.cls === 'blue' ? 'primary' : 'danger'});transition:.4s;"></div>
                    </div>
                    <span style="font-size:13px;font-weight:600;min-width:24px;text-align:right;">${it.count}</span>
                </div>`;
            }).join('');
            $('#statusBreakdown').html(html);
        }).fail(function () {
            $('#statTotal, #statRevenue, #statOutstanding').text('—');
        });

        // Customers count
        $.get('/api/customers', function (r) {
            $('#statCustomers').text((r.data || []).length);
        }).fail(function () { $('#statCustomers').text('—'); });

        // Recent invoices
        $.get('/api/invoices?page=1&size=6', function (r) {
            var invoices = r.data || [];
            var scMap = { Draft:'gray', Approved:'blue', Paid:'green', Cancelled:'red' };
            if (!invoices.length) {
                $('#recentInvoices tbody').html('<tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-muted);">No invoices yet.</td></tr>');
                return;
            }
            var rows = invoices.map(function (inv) {
                var sc = scMap[inv.status] || 'gray';
                return `<tr>
                    <td><a href="/Invoices/${inv.id}" style="color:var(--primary);font-weight:600;text-decoration:none;">${inv.invoiceNumber}</a></td>
                    <td style="font-size:12px;">${inv.customerName || '—'}</td>
                    <td style="font-weight:500;">৳ ${parseFloat(inv.totalAmount||0).toFixed(2)}</td>
                    <td style="color:${parseFloat(inv.outstandingBalance||0)>0?'var(--danger)':'var(--text-muted)'};">
                        ৳ ${parseFloat(inv.outstandingBalance||0).toFixed(2)}</td>
                    <td><span class="vbadge ${sc}">${inv.status}</span></td>
                    <td style="font-size:12px;color:var(--text-muted);">${inv.invoiceDate?new Date(inv.invoiceDate).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}):'—'}</td>
                </tr>`;
            }).join('');
            $('#recentInvoices tbody').html(rows);
        }).fail(function () {
            $('#recentInvoices tbody').html('<tr><td colspan="6" style="text-align:center;padding:24px;color:var(--text-muted);">Could not load invoices.</td></tr>');
        });

        // Low stock
        $.get('/api/products/low-stock?threshold=10', function (r) {
            var prods = r.data || [];
            if (!prods.length) return;
            $('#lowStockCard').show();
            var html = prods.slice(0, 5).map(function (p) {
                var sc = p.stockStatus === 'Out of Stock' ? 'red' : 'amber';
                return `<div style="display:flex;align-items:center;gap:10px;padding:9px 16px;border-bottom:.5px solid var(--card-border);">
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${p.productName}</div>
                        <div style="font-size:11px;color:var(--text-muted);">${p.productCode}</div>
                    </div>
                    <span class="vbadge ${sc}">Stock: ${p.stockQuantity}</span>
                </div>`;
            }).join('');
            $('#lowStockList').html(html);
        });

        // Pending users - Extracted safely using pure JS condition
        if (isUserAdmin) {
            $.get('/api/users/pending', function (r) {
                var users = (r.data || []).slice(0, 4);
                var cnt = (r.data || []).length;
                if (cnt > 0) {
                    $('#pendingBadgeBanner').text(cnt).show();
                }
                if (!users.length) {
                    $('#pendingMini').html('<div style="text-align:center;padding:16px;color:var(--text-muted);font-size:13px;"><i class="bi bi-check2-circle" style="font-size:20px;display:block;margin-bottom:6px;color:#22c55e;"></i>All clear!</div>');
                    return;
                }
                var html = users.map(function (u) {
                    return `<div style="display:flex;align-items:center;gap:10px;padding:9px 16px;border-bottom:.5px solid var(--card-border);">
                        <div class="sidebar-avatar" style="width:32px;height:32px;font-size:12px;">${u.name.charAt(0).toUpperCase()}</div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${u.name}</div>
                            <div style="font-size:11px;color:var(--text-muted);">${u.role}</div>
                        </div>
                        <button onclick="quickApprove(${u.id},this)" style="padding:4px 10px;background:var(--success-light);color:#15803d;border:none;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;">
                            Approve</button>
                    </div>`;
                }).join('');
                $('#pendingMini').html(html);
            });
        }
    });

    function quickApprove(id, btn) {
        $(btn).prop('disabled',true).text('…');
        $.ajax({ url:'/api/users/'+id+'/approve', method:'POST' })
            .done(function () {
                $(btn).closest('div[style*="display:flex"]').fadeOut(300, function(){ $(this).remove(); });
                showToast('User approved.','success');
            })
            .fail(function (xhr) {
                showToast(xhr.responseJSON?.message||'Failed.','danger');
                $(btn).prop('disabled',false).text('Approve');
            });
    }
  </script>
}
