@{
  ViewData["Title"] = "Dashboard";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Welcome Banner *@
<div style="background:linear-gradient(135deg,#1e4db7 0%,#1a40a0 100%);border-radius:14px;padding:24px 28px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;">
  <div>
    <div style="font-size:11px;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;">Welcome back</div>
    <div style="font-size:22px;font-weight:600;color:#fff;margin-bottom:4px;">@User.Identity?.Name</div>
    <div style="font-size:13px;color:rgba(255,255,255,.65);">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</div>
  </div>
  <div style="display:flex;gap:10px;">
    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
    {
      <a href="/admin/pending" class="btn-primary-v" style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);backdrop-filter:blur(4px);">
        <i class="bi bi-person-check"></i> Pending Users
      </a>
    }
    <a href="/Invoices/Create" class="btn-primary-v" style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.3);">
      <i class="bi bi-plus-lg"></i> New Invoice
    </a>
  </div>
</div>

@* Stats *@
<div class="stat-grid" style="margin-bottom:24px;">
  <div class="stat-card">
    <div class="stat-icon blue"><i class="bi bi-receipt"></i></div>
    <div><div class="stat-label">Total Invoices</div><div class="stat-value" id="statInvoices">—</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><i class="bi bi-building"></i></div>
    <div><div class="stat-label">Customers</div><div class="stat-value" id="statCustomers">—</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber"><i class="bi bi-box-seam"></i></div>
    <div><div class="stat-label">Products</div><div class="stat-value" id="statProducts">—</div></div>
  </div>
  @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
  {
    <div class="stat-card">
      <div class="stat-icon red"><i class="bi bi-hourglass-split"></i></div>
      <div><div class="stat-label">Pending Approvals</div><div class="stat-value" id="statPending">—</div></div>
    </div>
  }
</div>

@* Two-column layout *@
<div style="display:grid;grid-template-columns:1fr 340px;gap:20px;">

  @* Recent Activity *@
  <div class="vcard">
    <div class="vcard-header">
      <i class="bi bi-clock-history" style="font-size:15px;color:#64748b;"></i>
      <span class="vcard-title">Recent Invoices</span>
      <a href="/Invoices" class="btn-outline-v" style="margin-left:auto;padding:5px 12px;font-size:12px;">
        View All <i class="bi bi-arrow-right" style="font-size:11px;"></i>
      </a>
    </div>
    <div style="overflow-x:auto;">
      <table class="vtable" id="recentInvoices">
        <thead>
          <tr>
            <th>Invoice #</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="5" style="text-align:center;padding:32px;color:var(--text-muted);">
              <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
              <span style="margin-left:8px;font-size:13px;">Loading…</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  @* Quick Actions + Pending Panel *@
  <div style="display:flex;flex-direction:column;gap:16px;">

    @* Quick Actions *@
    <div class="vcard">
      <div class="vcard-header">
        <i class="bi bi-lightning-fill" style="font-size:15px;color:#64748b;"></i>
        <span class="vcard-title">Quick Actions</span>
      </div>
      <div class="vcard-body" style="display:flex;flex-direction:column;gap:8px;">
        <a href="/Customers/Create" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:9px;text-decoration:none;color:var(--text-primary);background:var(--body-bg);transition:.14s;" onmouseover="this.style.background='var(--primary-light)'" onmouseout="this.style.background='var(--body-bg)'">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:15px;"><i class="bi bi-building-add"></i></div>
          <span style="font-size:13px;font-weight:500;">Add Customer</span>
          <i class="bi bi-chevron-right" style="font-size:11px;color:var(--text-muted);margin-left:auto;"></i>
        </a>
        <a href="/Products/Create" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:9px;text-decoration:none;color:var(--text-primary);background:var(--body-bg);transition:.14s;" onmouseover="this.style.background='var(--warning-light)'" onmouseout="this.style.background='var(--body-bg)'">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--warning-light);color:var(--warning);display:flex;align-items:center;justify-content:center;font-size:15px;"><i class="bi bi-box-seam-fill"></i></div>
          <span style="font-size:13px;font-weight:500;">Add Product</span>
          <i class="bi bi-chevron-right" style="font-size:11px;color:var(--text-muted);margin-left:auto;"></i>
        </a>
        <a href="/Invoices/Create" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:9px;text-decoration:none;color:var(--text-primary);background:var(--body-bg);transition:.14s;" onmouseover="this.style.background='var(--success-light)'" onmouseout="this.style.background='var(--body-bg)'">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--success-light);color:var(--success);display:flex;align-items:center;justify-content:center;font-size:15px;"><i class="bi bi-receipt-cutoff"></i></div>
          <span style="font-size:13px;font-weight:500;">Create Invoice</span>
          <i class="bi bi-chevron-right" style="font-size:11px;color:var(--text-muted);margin-left:auto;"></i>
        </a>
      </div>
    </div>

    @* Pending Approvals Mini Panel *@
    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
    {
      <div class="vcard">
        <div class="vcard-header">
          <i class="bi bi-person-check" style="font-size:15px;color:#64748b;"></i>
          <span class="vcard-title">Awaiting Approval</span>
          <a href="/admin/pending" style="margin-left:auto;font-size:12px;color:var(--primary);text-decoration:none;">See all</a>
        </div>
        <div id="pendingMini" style="padding:8px 0;">
          <div style="text-align:center;padding:16px;color:var(--text-muted);font-size:13px;">
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <span style="margin-left:8px;">Loading…</span>
          </div>
        </div>
      </div>
    }
  </div>
</div>

@section Scripts {
  <script>
    $(function () {
        // ── Load stats
        function loadStats() {
            $.get('/api/users/pending', function (r) { $('#statPending').text(r.data?.length ?? 0); });
            // Customers & Products counts — adjust URLs to your actual API endpoints
            $.get('/api/customers', function (r) { $('#statCustomers').text(r.data?.length ?? r.length ?? '—'); }).fail(function() { $('#statCustomers').text('—'); });
            $.get('/api/products', function (r) { $('#statProducts').text(r.data?.length ?? r.length ?? '—'); }).fail(function() { $('#statProducts').text('—'); });
            $.get('/api/invoices', function (r) { $('#statInvoices').text(r.data?.length ?? r.length ?? '—'); }).fail(function() { $('#statInvoices').text('—'); });
        }
        loadStats();

        // ── Load recent invoices
        $.get('/api/invoices?page=1&size=6', function (r) {
            var invoices = r.data || r || [];
            var statusColor = { 'Draft': 'gray', 'Sent': 'blue', 'Paid': 'green', 'Overdue': 'red', 'Cancelled': 'gray' };
            if (!invoices.length) {
                $('#recentInvoices tbody').html('<tr><td colspan="5" style="text-align:center;padding:32px;color:var(--text-muted);">No invoices yet.</td></tr>');
                return;
            }
            var rows = invoices.map(function (inv) {
                var sc = statusColor[inv.status] || 'gray';
                return `<tr>
                    <td><a href="/Invoices/${inv.id}" style="color:var(--primary);font-weight:500;text-decoration:none;">${inv.invoiceNumber}</a></td>
                    <td style="font-size:12px;">${inv.customerName || '—'}</td>
                    <td style="font-weight:500;">৳ ${parseFloat(inv.totalAmount || 0).toFixed(2)}</td>
                    <td><span class="vbadge ${sc}">${inv.status}</span></td>
                    <td style="font-size:12px;color:var(--text-muted);">${inv.invoiceDate ? new Date(inv.invoiceDate).toLocaleDateString('en-GB', {day:'2-digit',month:'short',year:'numeric'}) : '—'}</td>
                </tr>`;
            }).join('');
            $('#recentInvoices tbody').html(rows);
        }).fail(function () { $('#recentInvoices tbody').html('<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-muted);">Could not load invoices.</td></tr>'); });

        // ── Pending mini panel
        $.get('/api/users/pending', function (r) {
            var users = (r.data || []).slice(0, 4);
            if (!users.length) {
                $('#pendingMini').html('<div style="text-align:center;padding:16px 12px;color:var(--text-muted);font-size:13px;"><i class="bi bi-check2-circle" style="font-size:20px;display:block;margin-bottom:6px;color:#22c55e;"></i>All clear!</div>');
                return;
            }
            var html = users.map(function (u) {
                var initials = u.name.charAt(0).toUpperCase();
                return `<div style="display:flex;align-items:center;gap:10px;padding:9px 16px;border-bottom:0.5px solid var(--card-border);">
                    <div class="sidebar-avatar" style="width:32px;height:32px;font-size:12px;flex-shrink:0;">${initials}</div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${u.name}</div>
                        <div style="font-size:11px;color:var(--text-muted);">${u.role}</div>
                    </div>
                    <button onclick="quickApprove(${u.id}, this)" style="padding:4px 10px;background:var(--success-light);color:#15803d;border:none;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;">Approve</button>
                </div>`;
            }).join('');
            $('#pendingMini').html(html);
        });
    });

    function quickApprove(id, btn) {
        $(btn).prop('disabled', true).text('…');
        $.ajax({ url: '/api/users/' + id + '/approve', method: 'POST' })
            .done(function () {
                $(btn).closest('div[style*="display:flex"]').fadeOut(300, function () { $(this).remove(); });
                showToast('User approved.', 'success');
                var cur = parseInt($('#statPending').text()) || 0;
                $('#statPending').text(Math.max(0, cur - 1));
            })
            .fail(function (xhr) {
                showToast(xhr.responseJSON?.message || 'Failed.', 'danger');
                $(btn).prop('disabled', false).text('Approve');
            });
    }
  </script>
}
