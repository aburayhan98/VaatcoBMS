@{
    var successMessage = TempData["Success"] as string;
    var errorMessage = TempData["Error"] as string ?? TempData["error"] as string;
    var infoMessage = TempData["Info"] as string;
    var warningMessage = TempData["Warning"] as string;
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof showToast === 'function') {
                showToast('@Html.Raw(successMessage.Replace("'", "\\'").Replace("\n", " "))', 'success');
            }
        });
    </script>
}

